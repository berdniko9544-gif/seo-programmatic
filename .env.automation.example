# ============================================================
# AUTOMATION ENVIRONMENT VARIABLES
# ============================================================

# Vercel Configuration
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM=team_xxxxxxxxxxxxx

# Yandex Webmaster API
YANDEX_WEBMASTER_TOKEN=your_yandex_token_here
YANDEX_USER_ID=your_user_id_here

# Google APIs (optional)
GOOGLE_INDEXING_API_KEY=your_google_api_key
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# OpenAI/Anthropic (для генерации контента)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# ============================================================
# КАК ПОЛУЧИТЬ КЛЮЧИ
# ============================================================

# Vercel Token:
# 1. Откройте https://vercel.com/account/tokens
# 2. Создайте новый токен
# 3. Скопируйте и вставьте выше

# Vercel Team ID (для Pro аккаунтов):
# 1. Откройте https://vercel.com/teams
# 2. Выберите команду
# 3. ID команды в URL: vercel.com/teams/TEAM_ID

# Yandex Webmaster:
# 1. Откройте https://oauth.yandex.ru/
# 2. Создайте приложение с доступом к Webmaster API
# 3. Получите токен
# 4. User ID найдите в Яндекс Вебмастер

# Google Indexing API:
# 1. Откройте https://console.cloud.google.com/
# 2. Создайте проект
# 3. Включите Indexing API
# 4. Создайте Service Account
# 5. Скачайте JSON ключ
