# ============================================================
# ENVIRONMENT VARIABLES FOR AUTOMATION
# ============================================================

# DeepSeek API (REQUIRED for AI content generation)
DEEPSEEK_API_KEY=sk-0745998fd651417cb649a864d5f427de

# Vercel Configuration (REQUIRED for deployment)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM=your_vercel_team_id_here

# Revalidation Secret (REQUIRED for ISR)
REVALIDATE_SECRET=your_random_secret_here

# Yandex Webmaster API (OPTIONAL for auto SEO)
YANDEX_WEBMASTER_TOKEN=your_yandex_token_here
YANDEX_USER_ID=your_user_id_here

# Google APIs (OPTIONAL)
GOOGLE_INDEXING_API_KEY=your_google_api_key
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=Your Site Name

# ============================================================
# GITHUB SECRETS (for GitHub Actions)
# ============================================================

# Add these secrets to your GitHub repository:
# Settings → Secrets and variables → Actions → New repository secret

# Required:
# - DEEPSEEK_API_KEY
# - VERCEL_TOKEN
# - VERCEL_TEAM (if using Vercel Pro)
# - REVALIDATE_SECRET

# Optional:
# - YANDEX_WEBMASTER_TOKEN
# - YANDEX_USER_ID

# ============================================================
# HOW TO GET KEYS
# ============================================================

# DeepSeek API Key:
# Already provided: sk-0745998fd651417cb649a864d5f427de

# Vercel Token:
# 1. Go to https://vercel.com/account/tokens
# 2. Create new token
# 3. Copy and paste above

# Vercel Team ID:
# 1. Go to https://vercel.com/teams
# 2. Select your team
# 3. Team ID is in URL: vercel.com/teams/TEAM_ID

# Revalidation Secret:
# Generate random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Yandex Webmaster:
# 1. Go to https://oauth.yandex.ru/
# 2. Create app with Webmaster API access
# 3. Get token
# 4. Find User ID in Yandex Webmaster
